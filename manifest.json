{
  "manifest_version": 3,
  "name": "X Blue Delete",
  "version": "1.1.1",
  "description": "Hide X Premium and verification upsell UI on X/Twitter.",
  "action": {
    "default_title": "X Blue Delete"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.twitter.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
